# The domain you want to deploy to. Replace 'your-domain.com' with your actual domain or IP address.
{$DOMAIN:your-domain.com} {
    # Route API requests to the backend container
    handle_path /api/* {
        reverse_proxy api:8000
    }

    # Route all other requests to the frontend container
    handle {
        reverse_proxy frontend:80
    }

    # Enable compression
    encode gzip zstd
}
