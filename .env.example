# ============================================
# UsePDF — Environment Configuration
# ============================================
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env

# --- Redis ---
# Connection URL for the Redis instance used by Celery and caching.
# Default uses the Docker Compose service name "redis".
REDIS_URL=redis://redis:6379/0

# --- File Storage ---
# Directory where uploaded PDF files are stored (inside the container).
UPLOAD_DIR=/data/uploads

# Directory where processed/result files are stored (inside the container).
RESULT_DIR=/data/results

# --- Upload Limits ---
# Maximum allowed file size for uploads, in megabytes.
MAX_FILE_SIZE_MB=100

# --- Auto-Cleanup ---
# Time-to-live for uploaded and result files, in seconds.
# Files older than this are automatically deleted. Default: 3600 (1 hour).
FILE_TTL_SECONDS=3600

# --- CORS ---
# Comma-separated list of allowed origins for CORS.
# Add your production domain here when deploying.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
